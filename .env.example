# Database (local dev — matches docker-compose.yml)
DATABASE_URL=postgresql://hlp:hlp_dev@localhost:5432/hlp_dev

# Auth
SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Anthropic (for LLM extraction)
ANTHROPIC_API_KEY=

# File storage base path (local dev)
STORAGE_BASE_PATH=./data/storage

# Email access (optional — for email reader agent)
# EMAIL_PROVIDER=imap
# IMAP_HOST=
# IMAP_USER=
# IMAP_PASSWORD=

# Portal credentials (optional — for portal access agent)
# PORTAL_CREDS_JSON={}

# App config
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
